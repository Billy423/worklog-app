# Vite exposes only variables prefixed with VITE_ to the browser bundle.
# DO NOT put server-side secrets here — they would ship to every client.

# ---------- API ----------
# Leave blank in dev — the Vite dev server proxies /api → http://localhost:3000.
# In prod (Azure), set to the deployed backend origin.
VITE_API_BASE_URL=

# ---------- Auth — Azure AD (Entra ID) ----------
# Public values (client id is not a secret in OAuth public client flows).
VITE_AZURE_TENANT_ID=
VITE_AZURE_CLIENT_ID=
# Scopes requested when acquiring an access token for the WorkLog API.
# Typically `api://<backend-client-id>/.default` or a custom scope.
VITE_AZURE_API_SCOPE=
# Redirect URI registered in the Azure AD app — usually the frontend origin.
VITE_AZURE_REDIRECT_URI=http://localhost:5173
