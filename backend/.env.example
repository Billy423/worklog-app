# Application
NODE_ENV=development
PORT=3000

# WorkLog Database (PostgreSQL)
DATABASE_URL=postgresql://worklog:password@postgres:5432/worklog

# CORS allowed origin (production only — dev defaults to http://localhost:5173)
CORS_ORIGIN=

# ArcGIS REST API
ARCGIS_API_KEY=

# PME SQL Server (ION_Network + ION_Data)
PME_HOST=172.26.118.107
PME_INSTANCE=ION
PME_USER=ads\wu897
PME_PASSWORD=
# Set to true to use Windows Authentication (Kerberos/NTLM); false = SQL auth
PME_WINDOWS_AUTH=true

# Sync schedule (cron expression — default: 2 AM daily)
SYNC_CRON=0 2 * * *
