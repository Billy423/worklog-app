# ---------- Application ----------
NODE_ENV=development
PORT=3000
LOG_LEVEL=debug

# ---------- WorkLog Database (PostgreSQL) ----------
# Use the same password as POSTGRES_PASSWORD in the root .env (Docker Compose substitutes it).
DATABASE_URL=postgresql://worklog:devpassword@postgres:5432/worklog

# ---------- CORS ----------
# Production only — dev defaults to http://localhost:5173 (Vite).
CORS_ORIGIN=

# ---------- Auth — Azure AD (Entra ID) ----------
# Tenant + app registration (provisioned by McMaster IT for production).
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
# Audience the access token is issued for — typically `api://<client-id>` or the client id itself.
AZURE_AUDIENCE=

# ---------- Auth — Dev Bypass ----------
# Skip Azure AD token validation. Logs a WARN on every request.
# NEVER set to true in production.
AUTH_BYPASS=true
# Role assigned to the stub user when AUTH_BYPASS=true. One of: technician, admin
AUTH_BYPASS_ROLE=admin

# ---------- ArcGIS REST API ----------
ARCGIS_API_KEY=

# ---------- PME SQL Server (ION_Network + ION_Data) ----------
PME_HOST=172.26.118.107
PME_INSTANCE=ION
PME_USER=ads\wu897
PME_PASSWORD=
# true = Windows Auth (Kerberos/NTLM); false = SQL auth
PME_WINDOWS_AUTH=true

# ---------- Sync Schedule ----------
# Cron expression — default: 2 AM daily
SYNC_CRON=0 2 * * *
