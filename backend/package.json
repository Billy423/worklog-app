{
  "name": "worklog-backend",
  "version": "0.1.0",
  "private": true,
  "description": "WorkLog API server — McMaster Facility Services",
  "main": "dist/server.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "eslint src tests --ext .ts",
    "migrate": "node-pg-migrate up",
    "migrate:create": "node-pg-migrate create"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.18.3",
    "express-rate-limit": "^7.3.1",
    "helmet": "^7.1.0",
    "mssql": "^11.0.1",
    "node-cron": "^3.0.3",
    "node-pg-migrate": "^7.3.2",
    "pg": "^8.11.5",
    "pino": "^9.2.0",
    "pino-http": "^10.2.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.14.0",
    "@types/node-cron": "^3.0.11",
    "@types/pg": "^8.11.6",
    "@typescript-eslint/eslint-plugin": "^7.13.0",
    "@typescript-eslint/parser": "^7.13.0",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "pino-pretty": "^11.2.1",
    "ts-jest": "^29.1.4",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.5"
  }
}
